---
import Layout from '../layouts/Layout.astro';

const team = [
	{
		name: 'Tim O\'Hagan',
		title: 'Chief Executive Officer',
		bio: 'Leading JKS International with a focus on Indigenous language reclamation, educational technology, and strategic market analysis.'
	},
	{
		name: 'Mutsumi O\'Hagan',
		title: 'Chief Logistics Officer',
		bio: 'Overseeing operational excellence and strategic coordination across the JKS portfolio.'
	},
	{
		name: 'Lorelei O\'Hagan',
		title: 'Director of Community Engagement',
		bio: 'Building authentic partnerships with Indigenous communities and leading relationship management across Languages 4 initiatives.'
	},
	{
		name: 'Jennie Korneychuk',
		title: 'Media Consultant & Strategist',
		bio: 'Emmy-winning producer creating vibrant language learning content and strategic media solutions.'
	}
];
---

<Layout title="About - JKS International">
	<!-- Hero -->
	<section class="py-24 bg-gradient-to-br from-gray-50 to-white">
		<div class="max-w-4xl mx-auto px-6 lg:px-8">
			<h1 class="text-5xl md:text-6xl font-light tracking-tight mb-6">
				Building the future<br />one venture at a time
			</h1>
			<p class="text-xl text-gray-600 leading-relaxed">
				JKS International is a holding company with a diverse portfolio spanning language technology, financial markets, sports innovation, and software development. We believe in building businesses that create meaningful impact while maintaining operational excellence.
			</p>
		</div>
	</section>

	<!-- Leadership Team -->
	<section class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<h2 class="text-sm uppercase tracking-wider text-gray-500 mb-12">Leadership Team</h2>
			<div class="grid md:grid-cols-2 gap-12">
				{team.map((member) => (
					<div class="border-l-2 border-blue-500 pl-8">
						<div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full mb-6"></div>
						<h3 class="text-2xl font-light mb-2">{member.name}</h3>
						<p class="text-sm uppercase tracking-wider text-gray-500 mb-4">{member.title}</p>
						<p class="text-gray-600 leading-relaxed">{member.bio}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Values -->
	<section class="py-24 bg-gradient-to-br from-gray-50 to-white">
		<div class="max-w-5xl mx-auto px-6 lg:px-8">
			<h2 class="text-sm uppercase tracking-wider text-gray-500 mb-12">Our Approach</h2>
			<div class="grid md:grid-cols-3 gap-8">
				<div>
					<div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg mb-4 flex items-center justify-center text-white">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
						</svg>
					</div>
					<h3 class="text-xl font-light mb-3">Innovation</h3>
					<p class="text-gray-600">Leveraging cutting-edge technology to solve real-world problems</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg mb-4 flex items-center justify-center text-white">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
						</svg>
					</div>
					<h3 class="text-xl font-light mb-3">Integrity</h3>
					<p class="text-gray-600">Building long-term partnerships based on trust and transparency</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-lg mb-4 flex items-center justify-center text-white">
						<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					</div>
					<h3 class="text-xl font-light mb-3">Impact</h3>
					<p class="text-gray-600">Creating businesses that make a meaningful difference</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
