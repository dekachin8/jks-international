---
import Layout from '../layouts/Layout.astro';

const businesses = [
	{
		name: 'Languages 4',
		description: 'Indigenous language reclamation and educational technology',
		link: 'https://www.languages4.com',
		icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>`
	},
	{
		name: 'JK Traders',
		description: 'Strategic options trading and market analysis',
		link: null,
		icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`
	},
	{
		name: 'VISUALIZE SPORTS',
		description: 'Premium golf training and visualization products',
		link: 'https://www.visualizesports.com',
		icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>`
	},
	{
		name: 'JKS Media',
		description: 'Software and web development solutions',
		link: null,
		icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`
	},
	{
		name: 'JKS.AI',
		description: 'Artificial intelligence integration and consulting',
		link: null,
		icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`
	}
];
---

<Layout title="JKS International - Building Businesses That Make an Impact">
	<!-- Hero -->
	<section class="relative min-h-[60vh] flex items-center justify-center bg-gradient-to-br from-gray-50 to-white overflow-hidden">
		<!-- Unique flowing abstract background -->
		<svg class="absolute inset-0 w-full h-full opacity-[0.08]" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice">
			<defs>
				<filter id="soften">
					<feGaussianBlur in="SourceGraphic" stdDeviation="2" />
				</filter>
			</defs>
			<!-- Flowing organic curves -->
			<path d="M 0,200 Q 300,100 600,200 T 1200,200" stroke="#000" stroke-width="2" fill="none" filter="url(#soften)" />
			<path d="M 0,300 Q 200,250 400,300 T 800,300 T 1200,300" stroke="#000" stroke-width="1.5" fill="none" filter="url(#soften)" opacity="0.6" />
			<path d="M 0,150 Q 400,50 800,150 T 1200,150" stroke="#000" stroke-width="1" fill="none" filter="url(#soften)" opacity="0.4" />
			<!-- Abstract flowing shapes -->
			<circle cx="150" cy="100" r="60" fill="#000" opacity="0.15" filter="url(#soften)" />
			<circle cx="1050" cy="500" r="80" fill="#000" opacity="0.12" filter="url(#soften)" />
			<circle cx="600" cy="50" r="40" fill="#000" opacity="0.1" filter="url(#soften)" />
			<!-- Curved flowing lines -->
			<path d="M 100,400 Q 300,300 500,400 Q 700,500 900,400" stroke="#000" stroke-width="2" fill="none" filter="url(#soften)" opacity="0.5" />
			<path d="M 0,500 Q 200,450 400,500 T 800,500 T 1200,500" stroke="#000" stroke-width="1" fill="none" filter="url(#soften)" opacity="0.3" />
			<!-- Diagonal flowing elements -->
			<path d="M 0,0 Q 300,300 600,200 Q 900,100 1200,400" stroke="#000" stroke-width="1.5" fill="none" filter="url(#soften)" opacity="0.4" />
			<path d="M 1200,0 Q 900,200 600,300 Q 300,400 0,600" stroke="#000" stroke-width="1" fill="none" filter="url(#soften)" opacity="0.3" />
		</svg>
		
		<div class="relative w-full mx-auto px-6 lg:px-8 text-center">
			<!-- JKS Logo -->
			<div class="mx-auto w-full h-auto" style="margin-bottom: 0; margin-top: -170px; max-width: 1000px;">
				<img src="/jks-logo-w-type.svg" alt="JKS International Logo" class="w-full h-auto" />
			</div>
		</div>
	</section>

	<!-- Portfolio -->
	<section class="py-8 bg-white relative" style="margin-top: -170px; z-index: 10;">
		<div class="max-w-7xl mx-auto px-6 lg:px-8">
			<h2 class="text-sm uppercase tracking-wider text-gray-500 mb-6">Our Portfolio</h2>
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
				{businesses.map((business) => (
					<div class="group border border-gray-100 p-4 hover:border-gray-300 hover:shadow-lg transition-all duration-300">
						<div class="w-16 h-16 rounded-lg mb-6 flex items-center justify-center text-white group-hover:scale-110 transition-transform" style="background-color: #183e4b;" set:html={business.icon}></div>
						<h3 class="text-2xl font-light mb-3">{business.name}</h3>
						<p class="text-gray-600 mb-4">{business.description}</p>
						{business.link && (
							<a
								href={business.link}
								target="_blank"
								rel="noopener noreferrer"
								class="text-sm inline-flex items-center gap-2" style="color: #183e4b;"
							>
								Visit site
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						)}
						<!-- Social Links -->
						{business.name === 'Languages 4' && (
							<div class="flex gap-3 mt-4">
								<a href="https://instagram.com/l4_languages4" target="_blank" rel="noopener noreferrer" class="transition" style="color: #183e4b;" aria-label="Languages 4 Instagram">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"/><path d="M12 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
								</a>
								<a href="https://linkedin.com/companies/languages4" target="_blank" rel="noopener noreferrer" class="transition" style="color: #183e4b;" aria-label="LinkedIn">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
								</a>
								<a href="https://twitter.com/l4languages4" target="_blank" rel="noopener noreferrer" class="transition" style="color: #183e4b;" aria-label="Twitter">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
								</a>
								<a href="https://facebook.com/profile.php?id=100090258725077" target="_blank" rel="noopener noreferrer" class="transition" style="color: #183e4b;" aria-label="Facebook">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
								</a>
							</div>
						)}
						{business.name === 'VISUALIZE SPORTS' && (
							<div class="flex gap-3 mt-4">
								<a href="https://instagram.com/_visualize_golf" target="_blank" rel="noopener noreferrer" class="transition" style="color: #183e4b;" aria-label="VISUALIZE Golf Instagram">
									<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073z"/><path d="M12 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
								</a>
							</div>
						)}
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-24 text-white" style="background-color: #e07b5a;">
		<div class="max-w-4xl mx-auto px-6 lg:px-8 text-center">
			<h2 class="text-4xl md:text-5xl font-light mb-6">Let's work together</h2>
			<p class="text-xl text-gray-300 mb-8">
				Interested in partnering or learning more about our businesses?
			</p>
			<a 
				href="/contact" 
				class="inline-block bg-white text-gray-900 px-8 py-4 rounded hover:bg-gray-100 transition font-medium"
			>
				Get in touch
			</a>
		</div>
	</section>
</Layout>
