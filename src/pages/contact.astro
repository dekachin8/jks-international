---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - JKS International">
	<section class="relative min-h-[80vh] flex items-center justify-center py-24 overflow-hidden">
		<!-- Unique flowing abstract background -->
		<svg class="absolute inset-0 w-full h-full opacity-[0.08]" viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice">
			<defs>
				<filter id="soften-contact">
					<feGaussianBlur in="SourceGraphic" stdDeviation="2" />
				</filter>
			</defs>
			<!-- Flowing organic curves -->
			<path d="M 0,200 Q 300,100 600,200 T 1200,200" stroke="#000" stroke-width="2" fill="none" filter="url(#soften-contact)" />
			<path d="M 0,300 Q 200,250 400,300 T 800,300 T 1200,300" stroke="#000" stroke-width="1.5" fill="none" filter="url(#soften-contact)" opacity="0.6" />
			<path d="M 0,150 Q 400,50 800,150 T 1200,150" stroke="#000" stroke-width="1" fill="none" filter="url(#soften-contact)" opacity="0.4" />
			<!-- Abstract flowing shapes -->
			<circle cx="150" cy="100" r="60" fill="#000" opacity="0.15" filter="url(#soften-contact)" />
			<circle cx="1050" cy="500" r="80" fill="#000" opacity="0.12" filter="url(#soften-contact)" />
			<circle cx="600" cy="50" r="40" fill="#000" opacity="0.1" filter="url(#soften-contact)" />
			<!-- Curved flowing lines -->
			<path d="M 100,400 Q 300,300 500,400 Q 700,500 900,400" stroke="#000" stroke-width="2" fill="none" filter="url(#soften-contact)" opacity="0.5" />
			<path d="M 0,500 Q 200,450 400,500 T 800,500 T 1200,500" stroke="#000" stroke-width="1" fill="none" filter="url(#soften-contact)" opacity="0.3" />
			<!-- Diagonal flowing elements -->
			<path d="M 0,0 Q 300,300 600,200 Q 900,100 1200,400" stroke="#000" stroke-width="1.5" fill="none" filter="url(#soften-contact)" opacity="0.4" />
			<path d="M 1200,0 Q 900,200 600,300 Q 300,400 0,600" stroke="#000" stroke-width="1" fill="none" filter="url(#soften-contact)" opacity="0.3" />
		</svg>
		<div class="relative max-w-4xl mx-auto px-6 lg:px-8">
			<div class="grid md:grid-cols-2 gap-16">
				<!-- Left column -->
				<div>
					<h1 class="text-5xl font-light tracking-tight mb-6" style="color: #e07b5a;">
						Get in Touch
					</h1>
					<p class="text-xl text-gray-600 mb-12">
						Interested in partnering or learning more about our businesses? We'd love to hear from you.
					</p>
					
					<div class="space-y-8">
						<div>
							<h3 class="text-sm uppercase tracking-wider text-gray-500 mb-2">Email</h3>
							<a href="mailto:tim@jks-international.com" class="text-lg transition" style="color: #183e4b;">
								tim@jks-international.com
							</a>
						</div>
						
						<div>
							<h3 class="text-sm uppercase tracking-wider text-gray-500 mb-2">Location</h3>
							<p class="text-lg text-gray-900">Arizona, USA</p>
						</div>
					</div>
				</div>

				<!-- Right column - Decorative element -->
				<div class="hidden md:flex items-center justify-center">
					<div class="relative w-64 h-64 flex items-center justify-center">
						<!-- Envelope/message icon -->
						<svg class="w-32 h-32" viewBox="0 0 24 24" fill="none" stroke="#183e4b" stroke-width="1" opacity="0.3">
							<rect x="2" y="4" width="20" height="16" rx="2"/>
							<path d="M2 4l10 8 10-8"/>
						</svg>
					</div>
				</div>
			</div>

			<!-- Business cards -->
			<div class="mt-24 pt-12 border-t border-gray-200">
				<h2 class="text-sm uppercase tracking-wider text-gray-500 mb-8">Our Businesses</h2>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
					<div class="border border-gray-200 p-6 rounded hover:border-gray-300 transition">
						<h3 class="font-medium mb-2">Languages 4</h3>
						<a href="https://www.languages4.com" target="_blank" rel="noopener noreferrer" class="text-sm transition" style="color: #183e4b;">
							languages4.com →
						</a>
					</div>
					<div class="border border-gray-200 p-6 rounded">
						<h3 class="font-medium mb-2">JK Traders</h3>
						<p class="text-sm text-gray-500">Options trading</p>
					</div>
					<div class="border border-gray-200 p-6 rounded hover:border-gray-300 transition">
						<h3 class="font-medium mb-2">VISUALIZE SPORTS</h3>
						<a href="https://www.visualizesports.com" target="_blank" rel="noopener noreferrer" class="text-sm transition" style="color: #183e4b;">
							visualizesports.com →
						</a>
					</div>
					<div class="border border-gray-200 p-6 rounded">
						<h3 class="font-medium mb-2">JKS Media</h3>
						<p class="text-sm text-gray-500">Software & web development</p>
					</div>
					<div class="border border-gray-200 p-6 rounded">
						<h3 class="font-medium mb-2">JKS.AI</h3>
						<p class="text-sm text-gray-500">AI consulting</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
